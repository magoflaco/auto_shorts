# ═══════════════════════════════════════════════════
# Auto Shorts v2 — Variables de entorno (TEMPLATE)
# Copia este archivo como .env y rellena los valores.
# ═══════════════════════════════════════════════════

# Groq API Keys
GROQ_AUDIO_API_KEY=
GROQ_RESPONSE_API_KEY=

# Deepgram TTS
DEEPGRAM_API_KEY=

# Pollinations (imagen anime)
POLLINATIONS_API_KEY=

# Freesound (música de fondo)
FREESOUND_API_KEY=

# Discord webhook para notificaciones
DISCORD_WEBHOOK_URL=

# Intervalo entre uploads (horas)
INTERVALO_HORAS=3
